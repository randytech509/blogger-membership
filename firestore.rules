// ============================================================================
//  Règles de sécurité Firestore — projet andetaynews-counter
//  Déploiement : npx firebase-tools deploy --only firestore:rules
//  C'EST ICI que se joue la vraie sécurité (pas dans le fait de cacher l'apiKey).
// ============================================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers -------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasProfile() {
      return isSignedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return hasProfile() && userDoc().role == 'admin';
    }
    function isMember() {
      return hasProfile() && userDoc().role in ['member', 'admin'];
    }

    // --- Profils utilisateurs ------------------------------------------------
    match /users/{uid} {
      // Lecture d'un profil : le sien, ou n'importe lequel si admin.
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Lister toute la collection : réservé aux admins (espace admin).
      allow list: if isAdmin();

      // Création à la 1re connexion : rôle forcé à "member", uid cohérent.
      allow create: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'member';

      // Mise à jour :
      //  - l'utilisateur peut MAJ ses infos SANS changer son rôle ;
      //  - un admin peut tout modifier (y compris promouvoir un membre).
      allow update: if isSignedIn() && (
                      (request.auth.uid == uid
                        && request.resource.data.role == resource.data.role)
                      || isAdmin()
                    );

      allow delete: if isAdmin();
    }

    // --- Contenu premium (paywall inviolable) --------------------------------
    // Le vrai contenu vit ici, jamais dans le HTML Blogger. Lisible seulement
    // par un membre connecté ; écrit uniquement depuis l'espace admin.
    match /premiumContent/{postId} {
      allow read:               if isMember();
      allow create, update, delete: if isAdmin();
    }

    // Tout le reste est refusé par défaut.
    match /{document=**} { allow read, write: if false; }
  }
}
